{
  "env:port.key": "PORT",
  "env:redis-url.key": "REDIS_URL",
  "env:open-ai.key": "OPENAI_KEY",
  "redis:client-opt": {
    "DialTimeout": 10,
    "ReadTimeout": 5,
    "WriteTimeout": 5,
    "PoolTimeout": 10,
    "MaxRetries": 3
  },
  "rate-limit:limits": {
    "RequestPerDay": 100,
    "RequestPerMinute": 10
  }
}