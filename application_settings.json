{
  "port": {
    "default": "8080",
    "env": "PORT"
  },
  "env:redis-url.key": "REDIS_URL",
  "env:open-ai.key": "OPENAI_KEY",
  "redis:client-opt": {
    "DialTimeout": "10s",
    "ReadTimeout": "5s",
    "WriteTimeout": "5s",
    "PoolTimeout": "10s",
    "MaxRetries": 3
  },
  "rate-limit:limits": {
    "RequestPerDay": 100,
    "RequestPerMinute": 10
  }
}